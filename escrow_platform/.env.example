DEBUG=False
SECRET_KEY=replace-with-a-long-random-django-secret
ALLOWED_HOSTS=.railway.app,.up.railway.app
CORS_ALLOWED_ORIGINS=https://gigway-two.vercel.app
CSRF_TRUSTED_ORIGINS=https://gigway-two.vercel.app

# Railway PostgreSQL can provide DATABASE_URL automatically.
# If you use Railway reference variables instead, set PGDATABASE, PGUSER,
# PGPASSWORD, PGHOST, and PGPORT from the PostgreSQL service.
# DATABASE_URL=${{Postgres.DATABASE_URL}}

MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_B2C_SHORTCODE=600000
MPESA_PASSKEY=
MPESA_CALLBACK_BASE_URL=https://your-railway-backend-domain
MPESA_CALLBACK_URL=https://your-railway-backend-domain/api/mpesa/callback/deposit

ECONFIRM_V1_BASE_URL=https://econfirm.co.ke/api/v1
ECONFIRM_API_KEY=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@escrowgig.com
